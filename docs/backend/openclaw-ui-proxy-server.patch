+function buildIdleRunStatus() {
+  return {
+    state: "idle",
+    pending: false,
+    label: "Idle",
+    startedAt: null,
+    updatedAt: null,
+    runId: null,
+    error: null,
+    artifactCount: 0,
+    hasUploads: false,
+  };
+}
+
+function buildRunStatusLabel(runState) {
+  if (!runState) return "Idle";
+  if (runState.state === "error") return "Run failed";
+  if (runState.state === "completed") {
+    return runState.artifactCount > 0 ? "Completed with files" : "Completed";
+  }
+  if (runState.state === "running") {
+    return runState.hasUploads ? "Analyzing uploaded files" : "Generating response";
+  }
+  if (runState.state === "dispatching") {
+    return runState.hasUploads ? "Starting file analysis" : "Starting agent run";
+  }
+  if (runState.state === "queued") {
+    return runState.hasUploads ? "Queued uploaded files" : "Queued";
+  }
+  return "Idle";
+}
+
+function serializeRunStatus(runState) {
+  if (!runState) {
+    return buildIdleRunStatus();
+  }
+
+  return {
+    state: runState.state,
+    pending: Boolean(runState.pending),
+    label: buildRunStatusLabel(runState),
+    startedAt: runState.startedAt ?? null,
+    updatedAt: runState.updatedAt ?? null,
+    runId: runState.runId ?? null,
+    error: runState.error ?? null,
+    artifactCount: Number(runState.artifactCount ?? 0),
+    hasUploads: Boolean(runState.hasUploads),
+  };
+}
+
+function setRunState(sessionKey, nextState) {
+  runStateBySession.set(sessionKey, nextState);
+  return nextState;
 }
 
+function patchRunState(sessionKey, patch) {
+  const existing = runStateBySession.get(sessionKey);
+  if (!existing) return null;
+  const nextState = {
+    ...existing,
+    ...patch,
+    updatedAt: nowEpochMs(),
+  };
+  runStateBySession.set(sessionKey, nextState);
+  return nextState;
+}
+
+function hasNewAssistantReply(runState, messages, assistantText) {
+  if (!runState) return false;
+  if (!assistantText) return false;
+  if (messages.length <= Number(runState.beforeCount ?? 0)) return false;
+
+  const previousAssistant = String(runState.beforeLastAssistant ?? "");
+  return previousAssistant ? assistantText !== previousAssistant : true;
+}
+
+function syncRunStateFromHistory(sessionKey, messages, artifacts = []) {
+  const existing = runStateBySession.get(sessionKey);
+  if (!existing) {
+    return buildIdleRunStatus();
+  }
+
+  const assistantText = latestAssistantText(messages);
+  const artifactCount = Array.isArray(artifacts) ? artifacts.length : 0;
+
+  if (existing.state === "error") {
+    const errored = {
+      ...existing,
+      pending: false,
+      artifactCount,
+    };
+    runStateBySession.set(sessionKey, errored);
+    return serializeRunStatus(errored);
+  }
+
+  if (hasNewAssistantReply(existing, messages, assistantText)) {
+    const completed = {
+      ...existing,
+      state: "completed",
+      pending: false,
+      lastAssistant: assistantText,
+      artifactCount,
+      updatedAt: nowEpochMs(),
+    };
+    runStateBySession.set(sessionKey, completed);
+    return serializeRunStatus(completed);
+  }
+
+  const nextState =
+    messages.length > Number(existing.beforeCount ?? 0)
+      ? {
+          ...existing,
+          state: "running",
+          pending: true,
+          artifactCount,
+          updatedAt: nowEpochMs(),
+        }
+      : {
+          ...existing,
+          artifactCount,
+        };
+
+  runStateBySession.set(sessionKey, nextState);
+  return serializeRunStatus(nextState);
+}
+
+function getNewArtifactsForRun(sessionKey, artifacts = []) {
+  const existing = runStateBySession.get(sessionKey);
+  if (!existing) return [];
+  const artifactCountBefore = Math.max(0, Number(existing.artifactCountBefore ?? 0));
+  return artifacts.slice(artifactCountBefore);
+}
