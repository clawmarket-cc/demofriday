+async function writeJsonFileAtomic(targetPath, value) {
+  const tempPath = `${targetPath}.tmp-${process.pid}-${Date.now()}`;
+  await fs.writeFile(tempPath, JSON.stringify(value, null, 2), "utf8");
+  await fs.rename(tempPath, targetPath);
