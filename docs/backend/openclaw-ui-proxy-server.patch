+async function dispatchChatRunInBackground({
+  agentId,
+  conversationId,
+  sessionKey,
+  chatSendParams,
+}) {
+  try {
+    patchRunState(sessionKey, {
+      state: "dispatching",
+      pending: true,
+      error: null,
+    });
+
+    const run = await gatewayCall("chat.send", chatSendParams, {
+      expectFinal: false,
+      timeoutMs: 30000,
+    });
+
+    patchRunState(sessionKey, {
+      state: "running",
+      pending: true,
+      runId: run?.runId ?? null,
+      run,
+      error: null,
+    });
+  } catch (error) {
+    patchRunState(sessionKey, {
+      state: "error",
+      pending: false,
+      error: String(error?.message ?? error),
+    });
+    console.error(
+      `background chat dispatch failed for ${agentId}/${conversationId}: ${String(error?.message ?? error)}`,
+    );
+  }
 }
 
