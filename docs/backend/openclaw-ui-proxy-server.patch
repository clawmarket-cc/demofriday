+async function clearConversationSession(agentId, conversationId) {
+  const sessionKey = buildSessionKey(agentId, conversationId);
+  const { sessionsDir, storePath } = getAgentSessionPaths(agentId);
+  let store = {};
+
+  try {
+    const raw = await fs.readFile(storePath, "utf8");
+    const parsed = JSON.parse(raw);
+    store = parsed && typeof parsed === "object" ? parsed : {};
+  } catch (error) {
+    if (error?.code !== "ENOENT") throw error;
+  }
+
+  const existing = store?.[sessionKey];
+  if (existing) {
+    delete store[sessionKey];
+    await fs.mkdir(sessionsDir, { recursive: true });
+    await writeJsonFileAtomic(storePath, store);
+  }
+
+  const sessionId = trim(existing?.sessionId);
+  const transcriptCandidates = new Set();
+
+  if (sessionId) {
+    transcriptCandidates.add(path.join(sessionsDir, `${sessionId}.jsonl`));
+    try {
+      const entries = await fs.readdir(sessionsDir);
+      entries
+        .filter((name) => name.startsWith(`${sessionId}-topic-`) && name.endsWith(".jsonl"))
+        .forEach((name) => transcriptCandidates.add(path.join(sessionsDir, name)));
+    } catch (error) {
+      if (error?.code !== "ENOENT") throw error;
+    }
+  }
+
+  if (trim(existing?.sessionFile)) {
+    transcriptCandidates.add(existing.sessionFile);
+  }
+
+  for (const transcriptPath of transcriptCandidates) {
+    await removePathIfExists(transcriptPath);
+  }
+
+  return {
+    sessionKey,
+    sessionId: sessionId ?? null,
+    existed: Boolean(existing),
+    removedTranscriptCount: transcriptCandidates.size,
+  };
+}
